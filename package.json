{
  "name": "dentiscribe-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first Dental AI Scribe desktop application",
  "author": "",
  "license": "UNLICENSED",
  "main": "dist/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev:renderer": "cd src/renderer && next dev -p 3000",
    "copy:assets": "node -e \"require('fs').mkdirSync('dist/main/db',{recursive:true});require('fs').copyFileSync('src/main/db/schema.sql','dist/main/db/schema.sql')\"",
    "dev:main": "npm run copy:assets && tsc -p src/main/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:3000 && cross-env NODE_ENV=development electron dist/main/index.js",
    "dev": "concurrently -k -n renderer,main,electron -c blue,green,magenta \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "build:renderer": "cd src/renderer && next build",
    "build:main": "tsc -p src/main/tsconfig.json && npm run copy:assets",
    "build": "npm run build:renderer && npm run build:main",
    "package": "npm run build && electron-builder --win",
    "test": "jest",
    "typecheck": "tsc -p src/main/tsconfig.json --noEmit && tsc -p src/renderer/tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "build": {
    "appId": "org.dentiscribe.app",
    "productName": "DentiScribe AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "src/renderer/out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DentiScribe AI"
    }
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "better-sqlite3-multiple-ciphers": "^11.3.0",
    "electron-store": "^8.2.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "jest": "^29.7.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "ts-jest": "^29.2.2",
    "typescript": "^5.5.3",
    "wait-on": "^7.2.0"
  }
}
